# Woerden360 — environment variables

# Anthropic Claude API key — powers the Scenario Simulator (/scenarios).
# Without it the simulator falls back to a local heuristic engine so the demo
# still works, but real AI cascade-analysis requires a valid key.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the Claude model (default: claude-opus-4-7).
# e.g. claude-sonnet-4-6 for lower latency/cost.
# ANTHROPIC_MODEL=claude-opus-4-7
